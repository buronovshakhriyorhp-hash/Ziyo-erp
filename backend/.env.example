# ============================================
# ZIYO CHASHMASI ERP — Environment Variables
# ============================================

# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ziyo_chashmasi
DB_USER=postgres
DB_PASSWORD=your_strong_password
DB_POOL_MAX=10
DB_POOL_IDLE_MS=10000

# JWT Access Token (qisqa muddatli — 15 daqiqa)
JWT_ACCESS_SECRET=your_very_long_access_secret_min_32_chars_here
JWT_ACCESS_EXPIRES_IN=15m

# JWT Refresh Token (uzoq muddatli — 7 kun)
JWT_REFRESH_SECRET=your_very_long_refresh_secret_min_32_chars_here
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
